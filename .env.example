# === Telegram API credentials ===
# Get these from https://my.telegram.org/apps
API_ID=
API_HASH=

# === User account (for pinging bots) ===
# Phone number in international format
PHONE=+1234567890

# === Health monitoring bot ===
# Create a bot via @BotFather, paste the token here
# This bot handles /health commands and sends reports to the group
BOT_TOKEN=

# === Monitored bots ===
# Comma-separated usernames of bots to monitor (with @)
MONITORED_BOTS=@bot1,@bot2,@bot3

# === Report destination ===
# Chat ID of the group where status/reports are sent
# Add the health bot to this group first!
# To get the group ID: add @userinfobot to the group, or use the API
GROUP_ID=

# === Optional settings ===

# Comma-separated Telegram user IDs allowed to use /health
# Leave empty to allow everyone
ADMIN_IDS=

# Ping interval in seconds (default: 1800 = 30 min)
PING_INTERVAL=1800

# Ping timeout in seconds (default: 30)
PING_TIMEOUT=30

# Hours (UTC) to send detailed reports (default: 4,18)
REPORT_HOURS=4,18
